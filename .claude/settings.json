{
  "env": {
    "ENABLE_CLAUDEAI_MCP_SERVERS": "false"
  },
  "enabledPlugins": {
    "adobe-for-creativity@claude-plugins-official": false,
    "mercadopago@claude-plugins-official": false,
    "sentry@claude-plugins-official": false,
    "slack@claude-plugins-official": false,
    "telegram@claude-plugins-official": false,
    "airtable@claude-plugins-official": false,
    "zapier@claude-plugins-official": false,
    "github@claude-plugins-official": false,
    "posthog@claude-plugins-official": false,
    "chrome-devtools-mcp@claude-plugins-official": false,
    "serena@claude-plugins-official": false
  },
  "permissions": {
    "allow": [
      "Bash(heavy bun run test:*)",
      "Bash(heavy bun run typecheck:*)",
      "Bash(heavy bun run build:*)",
      "Bash(heavy bunx vitest:*)",
      "Bash(bun run test:*)",
      "Bash(bun run typecheck:*)",
      "Bash(bun run build:*)",
      "Bash(bun lint)",
      "Bash(bun run lint)",
      "Bash(bun install)",
      "Bash(bun install:*)",
      "Bash(bun run wt:*)",
      "Bash(bun run claude:size)",
      "Bash(bun run audit:migrations)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git fetch:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git worktree list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(ls:*)",
      "Bash(rg:*)",
      "Bash(wc:*)",
      "Bash(jq:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(shellcheck:*)",
      "Bash(~/.config/afiacao/psql-ro:*)",
      "Bash(/Users/lucassardenberg/.config/afiacao/psql-ro:*)",
      "Bash(bash scripts/pr-watch.sh:*)",
      "Bash(scripts/pr-watch.sh:*)",
      "Bash(bash scripts/codex-async.sh:*)",
      "Bash(scripts/codex-async.sh:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/check-gstack.sh\""
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/heavy-guard.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/destructive-bash-guard.sh\""
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/branch-pos-squash-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/migration-collision-guard.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/migration-immutability-guard.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/pos-compact-ptbr.sh\"",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/vigia-worktree.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-moneypath-nudge.sh\""
          }
        ]
      }
    ]
  }
}
